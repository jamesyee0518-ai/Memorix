{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memorix",
  "version": "0.1.1",
  "identifier": "com.memorix.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:services",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run prepare:bundle",
    "frontendDist": "../shell"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Memorix",
        "url": "index.html",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Local-first knowledge engine",
    "longDescription": "Memorix desktop shell for the local-first dual-mode knowledge engine."
  }
}
